<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.bizum.BizumController">

    <Label text="Amount to Send:" style="-fx-font-size: 18px; -fx-text-fill: gray;"/>
    <Label fx:id="amountLabel" text="0 €" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #00c4b5;"/>

    <HBox alignment="CENTER" spacing="15.0">
        <Button text="+ 20€" onAction="#add20" style="-fx-font-size: 16px;"/>
        <Button text="+ 50€" onAction="#add50" style="-fx-font-size: 16px;"/>
        <Button text="+ 100€" onAction="#add100" style="-fx-font-size: 16px;"/>
    </HBox>

    <GridPane alignment="CENTER" hgap="10" vgap="10">
        <Button text="1" onAction="#add1" style="-fx-font-size: 20px; -fx-min-width: 60px;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Button text="2" onAction="#add2" style="-fx-font-size: 20px; -fx-min-width: 60px;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Button text="3" onAction="#add3" style="-fx-font-size: 20px; -fx-min-width: 60px;" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

        <Button text="4" onAction="#add4" style="-fx-font-size: 20px; -fx-min-width: 60px;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Button text="5" onAction="#add5" style="-fx-font-size: 20px; -fx-min-width: 60px;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Button text="6" onAction="#add6" style="-fx-font-size: 20px; -fx-min-width: 60px;" GridPane.columnIndex="2" GridPane.rowIndex="1"/>

        <Button text="7" onAction="#add7" style="-fx-font-size: 20px; -fx-min-width: 60px;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Button text="8" onAction="#add8" style="-fx-font-size: 20px; -fx-min-width: 60px;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Button text="9" onAction="#add9" style="-fx-font-size: 20px; -fx-min-width: 60px;" GridPane.columnIndex="2" GridPane.rowIndex="2"/>

        <Button text="0" onAction="#add0" style="-fx-font-size: 20px; -fx-min-width: 60px;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Button text="Clear" onAction="#reset" style="-fx-font-size: 16px; -fx-min-width: 60px; -fx-text-fill: red;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
    </GridPane>

    <Button text="Send Bizum" onAction="#send" style="-fx-font-size: 20px; -fx-background-color: #00c4b5; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30;"/>

</VBox>