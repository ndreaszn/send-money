<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="25.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.bizum.BizumController">

    <Label text="Amount to Send:" style="-fx-font-size: 18px; -fx-text-fill: gray;"/>

    <Label fx:id="amountLabel" text="0 €" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #00c4b5;"/>

    <HBox alignment="CENTER" spacing="15.0">
        <Button text="0€" onAction="#reset" style="-fx-font-size: 16px;"/>
        <Button text="+ 20€" onAction="#add20" style="-fx-font-size: 16px;"/>
        <Button text="+ 50€" onAction="#add50" style="-fx-font-size: 16px;"/>
        <Button text="+ 100€" onAction="#add100" style="-fx-font-size: 16px;"/>
    </HBox>

    <Button text="Send Bizum" onAction="#send" style="-fx-font-size: 20px; -fx-background-color: #00c4b5; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30;"/>

</VBox>